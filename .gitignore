# env
.env
.env.*
!.env.example

# python
__pycache__
*.pyc
.venv
venv
.pytest_cache
.mypy_cache
.ruff_cache

# pipeline working data — large, raw, regenerable; not meant for git
data/*
!data/.gitkeep

# pipeline reports — by default ignore everything,
# then explicitly ALLOW the files we want to publish/share via Vercel.
reports/*
!reports/.gitkeep
!reports/report.md
!reports/top_zw_wordpress.csv
!reports/zwwp.db
!reports/site/
!reports/site/**

# supervisor runtime
logs/
.pipeline.pid
.live.pid
nohup.out

# editor / OS
.DS_Store
.idea
.vscode
*.swp
.vercel
