# Copy to .env and fill in. .env is gitignored.

# --- Optional paid sources (skip the ones you don't have) ---

# BuiltWith API — direct CMS lookup. ~$295/mo for the relevant tier.
BUILTWITH_API_KEY=

# similarweb — traffic estimates. Usage-priced. Only used for top 200 in stage 04.
SIMILARWEB_API_KEY=

# --- Free / cheap sources ---

# Cloudflare Radar — free for our scale. Get a token at
#   https://dash.cloudflare.com/profile/api-tokens (Read access for Radar)
CLOUDFLARE_API_TOKEN=

# Tranco — no key needed; download the CSV manually or scripts will fetch it.
TRANCO_CSV_PATH=./data/tranco_latest.csv

# Google Cloud (BigQuery) — for HTTP Archive queries in stage 01.
# Set up application default creds: `gcloud auth application-default login`
GOOGLE_CLOUD_PROJECT=

# --- Claude API (stage 05 categorization, stage 07 report writeup) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Crawl politeness ---
HTTP_USER_AGENT=zw-wp-research/0.1 (research; contact: munya@munyamakosa.com)
HTTP_RPS_PER_HOST=1
HTTP_TIMEOUT_SECONDS=15
