# Copy to .env and fill in. .env is gitignored.
#
# Free path: nothing here is required to run the pipeline.
# Stages 05 and 07 use the `claude` CLI (Max plan) — no API key needed.

# --- Optional: Cloudflare Radar (free tier) ---
# Mint a token at https://dash.cloudflare.com/profile/api-tokens (Read access for Radar).
# When set, stage 01 pulls "top sites by country=ZW" and stage 04 adds rank buckets.
CLOUDFLARE_API_TOKEN=

# --- Tranco list (free, no key needed) ---
# Path where stage 01 caches the Tranco top-1M CSV (auto-downloaded if missing).
TRANCO_CSV_PATH=./data/tranco_latest.csv

# --- Crawl politeness (used by all HTTP-fetching stages) ---
HTTP_USER_AGENT=zw-wp-research/0.1 (research; contact: munya@munyamakosa.com)
HTTP_RPS_PER_HOST=1
HTTP_TIMEOUT_SECONDS=15

# --- Claude CLI pacing (Max plan rate-limit hygiene) ---
# Global cap: at most CLAUDE_RPS calls/second across the pipeline.
# 0.5 = one call every 2 seconds. Raise carefully if you have headroom.
CLAUDE_RPS=0.5
ANTHROPIC_MODEL=claude-haiku-4-5

# --- v2 (deferred; left here for documentation) ---
# GOOGLE_CLOUD_PROJECT=        # HTTP Archive on BigQuery
# BUILTWITH_API_KEY=           # paid; we use our own detector instead
# SIMILARWEB_API_KEY=          # paid; not used
